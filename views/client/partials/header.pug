// Top Header
.top-header
  .container
    .inner-wrap
      .inner-item
        i.fa-solid.fa-phone
        | #{settingWebsiteInfo.phone}
      .inner-item
        i.fa-solid.fa-envelope
        | #{settingWebsiteInfo.email}
      .inner-item
        i.fa-solid.fa-building
        | #{settingWebsiteInfo.address}
// End Top Header
// Header
header.header
  .container
    .inner-wrap
      // Menu Mobile
      button.inner-menu-mobile
        i.fa-solid.fa-bars
      // Logo
      .inner-logo
        a(href="/")
          img(
            alt="28.TRAVEL" 
            src="/assets/images/logo.png"
            )
      // Menu
      nav.inner-menu
        ul
          li
            a.active(href="/") Trang chủ
          each item in categoryTree
            li
              a(href=`/category/${item.slug}`) #{item.name}
              i.fa-solid.fa-caret-down
              ul
                -if(item.children)
                each child in item.children
                  li
                    a(href=`/category/${child.slug}`) #{child.name}
          li
            a(href="#") Tin tức
          li
            a(href="#") Liên hệ
        .inner-overlay
      // Cart
      .inner-cart
        a(href="/cart")
          img(
            alt="Cart" 
            src="/assets/images/icon-cart.svg"
            )
          span 1
// End Header