extends ../layouts/default.pug


block main
  h1.box-title Nhóm quyền

  //- Section 5
  .section-5
    .inner-wrap
      .inner-change-status
        .inner-item
          select(setting-role-list-change-status)
            option(value="") -- Hành động --
            option(value="action-delete") Xóa
        .inner-item
          button(setting-role-list-apply) Áp dụng
      .inner-search
        <i class="fa-solid fa-magnifying-glass"></i>
        input(type="text" placeholder="Tìm kiếm" setting-role-list-search)
      .inner-button-create
        a(href=`/${pathAdmin}/setting/role/create`) + Tạo mới
  //- End Section 5

  //- Section 6
  .section-6
    .table-2
      table
        thead
          tr
            th(class="inner-center")
              input(type="checkbox" class="inner-check" setting-role-list-checkall)
            th Tên nhóm quyền
            th Mô tả ngắn
            th Hành động
        tbody
        each role in roleList
          tr
            td(class="inner-center")
              input(type="checkbox" class="inner-check" setting-role-list-check=role._id)
            td= role.name
            td= role.description
            td
              .inner-buttons
                a(href=`/${pathAdmin}/setting/role/edit/${role._id}` class="inner-edit") <i class="fa-regular fa-pen-to-square"></i>
                button(class="inner-delete" btn-delete-role-list=role._id) <i class="fa-regular fa-trash-can"></i>
  //- End Section 6